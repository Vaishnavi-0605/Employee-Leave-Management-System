<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Attendance</title>
        <link rel="stylesheet" href="/css/var.css?v=1.2">
    <link rel="stylesheet" href="/css/global.css?v=1.2">
    <link rel="stylesheet" href="/css/nav.css?v=1.2">
    <link rel="stylesheet" href="/css/sidebar.css?v=1.2">
    <link rel="stylesheet" href="/css/att.css?v=1.2">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">

      <style>
        a{
            text-decoration: none;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="box">
            <nav class="nav-bar">
                <div class="left">
                    <div class="menu" id="menu-btn">
                        <i class="bi bi-list"></i>
                    </div>
                    <div class="title">
                        <h1>PreLeave</h1>
                    </div>
                    <div class="search-bar">
                        <input type="text" id="search-bar">
                        <i class="bi bi-search"></i>
                    </div>
                </div>
                <div class="right">
                    <div class="notif">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <div class="toggle-dn">
                        <i class="bi bi-brightness-high-fill" id="theme-toggle"></i>
                    </div>
                    <div class="profile" onclick="window.location.href='/profile'">
                        <i class="bi bi-person-circle"></i>
                    </div>
                </div>
            </nav>

            <div class="main-area">
               <aside class="sidebar" id="sidebar">
                    <div class="aside-nav">
                        <a href="/dashboard" class="menu-item">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/employees" class="menu-item">
                            <i class="bi bi-people-fill"></i>
                            <span>Employees</span>
                        </a>
                        <a href="/leaves" class="menu-item">
                            <i class="bi bi-calendar-check"></i>
                            <span>Leave Requests</span>
                        </a>
                        <a href="/attendance" class="menu-item active"> 
                            <i class="bi bi-clock-history"></i>
                            <span>Attendance</span>
                        </a>
                        <a href="/calendar" class="menu-item">
                            <i class="bi bi-calendar-date-fill"></i>
                            <span>Calendar</span>
                        </a>

                        <a href="/changepass" class="menu-item">
                            <i class="bi bi-gear-fill"></i>
                            <span>Settings</span>
                        </a>
                        <a href="/login" class="menu-item">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </aside>

                <div class="content-box content" id="main-cont">
                    <div class="kpi-card">
                        <div class="attendance-cards">
                            <div class="attendance-card">
                                <h4>Overall Attendance</h4>
                                <h1><%= attendance.overallRate %></h1>
                                <p>↑ 4% from last month</p>
                            </div>
                            <div class="attendance-card">
                                <h4>Present</h4>
                                <h1><%= attendance.presentCount %></h1>
                                <span class="green-pill">Today</span>
                            </div>
                            <div class="attendance-card">
                                <h4>Absent</h4>
                                <h1><%= attendance.absentCount %></h1>
                                <span class="red-pill">Today</span>
                            </div>
                            <div class="attendance-card">
                                <h4>Late</h4>
                                <h1><%= attendance.lateCount %></h1>
                                <span class="orange-pill">Today</span>
                            </div>
                            <div class="attendance-card">
                                <h4>On Leave</h4>
                                <h1><%= attendance.onLeaveCount %></h1>
                                <span class="purple-pill">Today</span>
                            </div>
                        </div>
                    </div>

                    <div class="summary-table">
                        <div class="summary-head">
                            <div>Department</div>
                            <div>Total</div>
                            <div>Present</div>
                            <div>Absent</div>
                            <div>Late</div>
                            <div>On Leave</div>
                        </div>

                        <% attendance.dept.forEach(dept => { %>
                            <div class="summary-row">
                                <div><%= dept.name %></div>
                                <div><%= dept.total %></div>
                                <div><%= dept.present %></div>
                                <div><%= dept.absent %></div>
                                <div><%= dept.late %></div>
                                <div><%= dept.onLeave %></div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <div class="footer">
            <p>@Employee Management System</p>
        </div>
    </footer>
    <!-- <script src="/js/attendance.js"></script> -->
    <script src="/script2.js"></script>
</body>
</html>