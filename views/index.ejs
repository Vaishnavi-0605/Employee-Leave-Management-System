<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PreLeave Login</title>

    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
</head>

<body>

<div class="container">

    <div class="main">

        <div class="text-content">
            <h1>Welcome!</h1>
            <p>Sign in to continue to your Employee Portal</p>
        </div>

        <div class="form-area">

            <form action="/login" method="POST" class="login-form" id="loginfm">

                <input type="text" name="email" placeholder="Enter your email" id="email">
                <span id="emailError" style="color: red;"></span>

                <div class="password-wrapper">
                    <input type="password" name="password" placeholder="Enter your password" id="pass">
                    <i class="bi bi-eye-slash toggle-password" id="toggle-eye" onclick="togglePassword()"></i>
                    <span id="passError" style="color: red;"></span>
                </div>

                <button type="submit">Login</button>

            </form>

            <div class="divider">
                <hr>
                <span>or</span>
                <hr>
            </div>

            <p class="footer-text">
                New HR Manager? <a href="/register">Register Here</a>
            </p>

        </div>

    </div>

</div>

<script src="/js/index.js"></script>

</body>
</html>