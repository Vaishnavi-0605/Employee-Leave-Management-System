<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calendar</title>
        <link rel="stylesheet" href="/css/var.css?v=1.2">
    <link rel="stylesheet" href="/css/global.css?v=1.2">
    <link rel="stylesheet" href="/css/nav.css?v=1.2">
    <link rel="stylesheet" href="/css/sidebar.css?v=1.2">
    <link rel="stylesheet" href="/css/cln.css?v=1.2">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="cont">
            <nav class="nav-bar">
                <div class="left">
                    <div class="menu" id="menu-btn">
                        <i class="bi bi-list"></i>
                    </div>
                    <div class="title">
                        <h1>PreLeave</h1>
                    </div>
                </div>
                <div class="right">
                    <div class="profile" onclick="window.location.href='/profile'">
                        <i class="bi bi-person-circle"></i>
                    </div>
                </div>
            </nav>

            <div class="main-area">
                 <aside class="sidebar" id="sidebar">
                    <div class="aside-nav">
                        <a href="/dashboard" class="menu-item">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/employees" class="menu-item">
                            <i class="bi bi-people-fill"></i>
                            <span>Employees</span>
                        </a>
                        <a href="/leaves" class="menu-item">
                            <i class="bi bi-calendar-check"></i>
                            <span>Leave Requests</span>
                        </a>
                        <a href="/attendance" class="menu-item"> 
                            <i class="bi bi-clock-history"></i>
                            <span>Attendance</span>
                        </a>
                        <a href="/calendar" class="menu-item active">
                            <i class="bi bi-calendar-date-fill"></i>
                            <span>Calendar</span>
                        </a>

                        <a href="/changepass" class="menu-item">
                            <i class="bi bi-gear-fill"></i>
                            <span>Settings</span>
                        </a>
                        <a href="/login" class="menu-item">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </aside>

                <main class="content" id="main-cont" style="padding: 20px;">
                    <div class="calendar-card" style="background: white; padding: 20px; border-radius: 12px; height: 500px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                        <h3 style="margin-bottom: 15px; font-family: 'Manrope', sans-serif;">📅 Leave Calendar</h3>
                        <iframe src="https://calendar.google.com/calendar/embed?src=YOUR_CALENDAR_ID" style="border:0" width="100%" height="90%"></iframe>
                    </div>
                </main>
            </div>
        </div>
    </div>
    <footer>
        <div class="footer">
            <p>@Employee Management System</p>
        </div>
    </footer>
    <script src="/script2.js"></script>
</body>
</html>
