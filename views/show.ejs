<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Details</title>
        <link rel="stylesheet" href="/css/var.css?v=1.2">
    <link rel="stylesheet" href="/css/global.css?v=1.2">
    <link rel="stylesheet" href="/css/nav.css?v=1.2">
    <link rel="stylesheet" href="/css/sidebar.css?v=1.2">
    <link rel="stylesheet" href="/css/show.css?v=1.2">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">

</head>
<body>
    <div class="container">
        <div class="box">
            <nav class="nav-bar">
                <div class="left">
                    <div class="menu" id="menu-btn">
                        <i class="bi bi-list"></i>
                    </div>
                    <div class="title">
                        <h1>PreLeave</h1>
                    </div>
                    <div class="search-bar">
                        <input type="text" id="search-bar">
                        <i class="bi bi-search"></i>
                    </div>
                </div>
                <div class="right">
                    <div class="notif">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <div class="toggle-dn">
                        <i class="bi bi-brightness-high-fill" id="theme-toggle"></i>
                    </div>
                    <div class="profile" onclick="window.location.href='/profile'">
                        <i class="bi bi-person-circle"></i>
                    </div>
                </div>
            </nav>

            <div class="main-area">
               <aside class="sidebar" id="sidebar">
                    <div class="aside-nav">
                        <a href="/dashboard" class="menu-item">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/employees" class="menu-item">
                            <i class="bi bi-people-fill"></i>
                            <span>Employees</span>
                        </a>
                        <a href="/leaves" class="menu-item">
                            <i class="bi bi-calendar-check"></i>
                            <span>Leave Requests</span>
                        </a>
                        <a href="/attendance" class="menu-item active"> 
                            <i class="bi bi-clock-history"></i>
                            <span>Attendance</span>
                        </a>
                        <a href="/calendar" class="menu-item">
                            <i class="bi bi-calendar-date-fill"></i>
                            <span>Calendar</span>
                        </a>

                        <a href="/changepass" class="menu-item">
                            <i class="bi bi-gear-fill"></i>
                            <span>Settings</span>
                        </a>
                        <a href="/login" class="menu-item">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </aside>
                <main class="content" id="main-cont">
                    <div class="employee-profile">



    <div class="profile-left">

       <% if (emp.profile_picture) { %>

            <img src="/<%= emp.profile_picture %>" alt="<%= emp.full_name %>">

        <% } else { %>
        
            <img src="/images/profile.png" alt="Employee Profile">
        
        <% } %>



        <h3><%= emp.full_name %></h3>

        <p class="emp-id"><%= emp.employee_id %></p>
    </div>



    <div class="profile-right">
        <div class="detail">
            <span>Department</span>
            <p><%= emp.department %></p>

        </div>



        <div class="detail">

            <span>Position</span>

            <p><%= emp.position %></p>

        </div>

        <div class="detail">
                
            <span>Gender</span>
                
            <p><%= emp.gender %></p>
                
        </div>



        <div class="detail">

            <span>Email</span>

            <p><%= emp.email %></p>

        </div>



        <div class="detail">

            <span>Phone</span>

            <p><%= emp.phone %></p>

        </div>



        <div class="detail">

            <span>Date Joined</span>

            <p><%= emp.joining_date %></p>

        </div>



        <div class="detail">

            <span>Status</span>

            <p><%= emp.status %></p>

        </div>



        <div class="detail">

            <span>Total Attendance</span>

            <p><%= emp.attendance %></p>

        </div>



    </div>
                    </div>
                </main>
        </div>
    </div>
    <footer>
        <div class="footer">
            <p>@Employee Management System</p>
        </div>
    </footer>
    <script src="/js/attendance.js"></script>
    <script src="/script2.js"></script>
</body>
</html>
