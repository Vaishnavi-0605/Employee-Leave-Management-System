<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
        <link rel="stylesheet" href="/css/var.css?v=1.2">
    <link rel="stylesheet" href="/css/global.css?v=1.2">
    <link rel="stylesheet" href="/css/nav.css?v=1.2">
    <link rel="stylesheet" href="/css/sidebar.css?v=1.2">
    <link rel="stylesheet" href="/css/profile.css?v=1.2">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="container">
        <div class="cont">
            <nav class="nav-bar">
                <div class="left">
                    <div class="menu" id="menu-btn">
                        <i class="bi bi-list"></i>
                    </div>
                    <div class="title">
                        <h1>PreLeave</h1>
                    </div>
                    <div class="search-bar">
                        <input type="text" id="search-bar">
                        <i class="bi bi-search"></i>
                    </div>
                </div>
                <div class="right">
                    <div class="notif">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <div class="toggle-dn">
                        <i class="bi bi-brightness-high-fill" id="theme-toggle"></i>
                    </div>
                    <div class="profile" onclick="window.location.href='/profile'">
                        <i class="bi bi-person-circle"></i>
                    </div>
                </div>
            </nav>

            <div class="main-area">
                <aside class="sidebar" id="sidebar">
                    <div class="aside-nav">
                        <a href="/dashboard" class="menu-item" style="text-decoration: none; color: inherit;">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/employees" class="menu-item" style="text-decoration: none; color: inherit;">
                            <i class="bi bi-people-fill"></i>
                            <span>Employees</span>
                        </a>
                        <a href="/leaves" class="menu-item" style="text-decoration: none; color: inherit;">
                            <i class="bi bi-calendar-check"></i>
                            <span>Leave Requests</span>
                        </a>
                        <a href="/attendance" class="menu-item" style="text-decoration: none; color: inherit;"> 
                            <i class="bi bi-clock-history"></i>
                            <span>Attendance</span>
                        </a>
                        <a href="/calendar" class="menu-item" style="text-decoration: none; color: inherit;">
                            <i class="bi bi-calendar-date-fill"></i>
                            <span>Calendar</span>
                        </a>

                        <a href="/changepass" class="menu-item" style="text-decoration: none; color: inherit;">
                            <i class="bi bi-gear-fill"></i>
                            <span>Settings</span>
                        </a>
                        <a href="/login" class="menu-item" style="text-decoration: none; color: inherit;">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </aside>

                <div class="profile-page">
                    <div class="profile-card">
                        <div class="profile-pic">
                            <%= profile.empName[0] %>
                        </div>
                        <h2><%= profile.empName %></h2>
                        <p><%= profile.posn %></p>

                        <div class="profile-info">
                            <div><strong>ID:</strong> <%= profile.empId %></div>
                            <div><strong>Department:</strong> <%= profile.empDept %></div>
                            <div><strong>Email:</strong> <%= profile.empMail %></div>
                            <div><strong>Phone:</strong> <%= profile.empPh %></div>
                        </div>

                        <button class="change-pass" onclick="window.location.href='/changepass'">Change Password</button>
                    </div>

                    <div class="profile-right">
                        <div class="card">
                            <h2>Personal Information</h2>
                            <form action="/profile?_method=PUT" method="POST">
                                <div class="info-grid">
                                    <div>
                                        <label>Full Name</label>
                                        <input type="text" name="empName" value="<%= profile.empName %>" required>
                                    </div>
                                    <div>
                                        <label>Email</label>
                                        <input type="email" name="empMail" value="<%= profile.empMail %>" required>
                                    </div>
                                    <div>
                                        <label>Phone</label>
                                        <input type="text" name="empPh" value="<%= profile.empPh %>" required>
                                    </div>
                                    <div>
                                        <label>Gender</label>
                                        <input type="text" name="gender" value="<%= profile.gender %>" required>
                                    </div>
                                </div>
                                <button type="submit" class="save-btn" style="margin-top: 15px;">Save Changes</button>
                            </form>
                        </div>

                        <div class="small-cards">
                            <div class="card">
                                <h2>Employment Details</h2>
                                <p>Job Title: <%= profile.posn %></p>
                                <p>Department: <%= profile.empDept %></p>
                                <p>Status: <%= profile.status %></p>
                            </div>
                            <div class="card">
                                <h2>Leave Balance</h2>
                                <p>Casual Leave: <%= profile.leaveBalance.casual %></p>
                                <p>Sick Leave: <%= profile.leaveBalance.sick %></p>
                                <p>Earned Leave: <%= profile.leaveBalance.earned %></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <footer>
        <div class="footer">
            <p>@Employee Management System</p>
        </div>
    </footer>
    <script src="/js/profile.js"></script>
    <script src="/script2.js"></script>
</body>
</html>
