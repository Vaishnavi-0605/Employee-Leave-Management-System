<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employees</title>
        <link rel="stylesheet" href="/css/var.css?v=1.2">
    <link rel="stylesheet" href="/css/global.css?v=1.2">
    <link rel="stylesheet" href="/css/nav.css?v=1.2">
    <link rel="stylesheet" href="/css/sidebar.css?v=1.2">
    <link rel="stylesheet" href="/css/empl.css?v=1.2">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>

      <style>
        a{
            text-decoration: none;
        }

        .errorBox{
            color: red;
        }

        .embtn{
            background-color: var(--accent2);
        }
        .embtn:hover{
            background-color: var(--accents);
        }
        .cnbtn{
            background-color: gray;
        }
        .cnbtn:hover{
            background-color: rgba(70, 70, 70, 0.332);
        }
        option{
            background-color: var(--bg-col);
        }
        .profile-img{
            width:100%;
            height:100%;
            object-fit:cover;
            border-radius:50%;
        }
    </style>
</head>
<body>
    <div class="container">
         <div class="cont">
            <nav class="nav-bar">
                <div class="left">
                    <div class="menu" id="menu-btn">
                        <i class="bi bi-list"></i>
                    </div>
                    <div class="title">
                        <h1>PreLeave</h1>
                    </div>
                    <div class="search-bar">
                        <input type="text" id="search-bar">
                        <i class="bi bi-search"></i>
                    </div>
                </div>
                <div class="right">
                    <div class="notif">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <div class="toggle-dn">
                        <i class="bi bi-brightness-high-fill" id="theme-toggle"></i>
                    </div>
                    <div class="profile" onclick="window.location.href='/profile'">
                        <i class="bi bi-person-circle"></i>
                    </div>
                </div>
            </nav>

            <div class="main-area">
               <aside class="sidebar" id="sidebar">
                    <div class="aside-nav">
                        <a href="/dashboard" class="menu-item">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/employees" class="menu-item active">
                            <i class="bi bi-people-fill"></i>
                            <span>Employees</span>
                        </a>
                        <a href="/leaves" class="menu-item">
                            <i class="bi bi-calendar-check"></i>
                            <span>Leave Requests</span>
                        </a>
                        <a href="/attendance" class="menu-item"> 
                            <i class="bi bi-clock-history"></i>
                            <span>Attendance</span>
                        </a>
                        <a href="/calendar" class="menu-item">
                            <i class="bi bi-calendar-date-fill"></i>
                            <span>Calendar</span>
                        </a>

                        <a href="/changepass" class="menu-item">
                            <i class="bi bi-gear-fill"></i>
                            <span>Settings</span>
                        </a>
                        <a href="/login" class="menu-item">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </aside>

                <div class="employees-page content" id="main-cont">
                    <div class="filters">
                        <input type="text" placeholder="Search employee..." id="searchInput">
                        <select id="deptId">
                            <option>All Departments</option>
                            <option>Finance</option>
                            <option>Design</option>
                            <option>Marketing</option>
                            <option>Engineering</option>
                        </select>
                        <select>
                            <option>Attendance</option>
                        </select>
                        <select id="stat">
                            <option>All Status</option>
                            <option>Active</option>
                            <option>Inactive</option>
                        </select>
                        <button id="addEmployeeBtn">
                            <i class="bi bi-plus"></i>
                            Add Employee
                        </button>
                        <button class="exp">
                            <i class="bi bi-download"></i>
                            Export Report</button>
                    </div>

                    <div class="employee-table">
                        <div class="table-row table-header">
                            <div>Employee</div>
                            <div>Department</div>
                            <div>Attendance</div>
                            <div>Position</div>
                            <div>Date Joined</div>
                            <div>Status</div>
                            <div>Email ID</div>
                            <!-- <div>Actions</div> -->
                        </div>

                        <% employees.forEach(emp => { %>
                                <div class="table-row employee-row"
                                     data-name="<%= emp.full_name %>"
                                     data-dept="<%= emp.department %>"
                                     data-status="<%= emp.status %>"
                                     data-email="<%= emp.email %>">
                            <div class="employee-cell">
                                    <div class="avatar">
                                        <% if (emp.profile_picture) { %> 

                                        <img src="/<%= emp.profile_picture %>"
                                        class="profile-img">

                                        <% } else { %>
                                        
                                            <%= emp.full_name.split(" ").map(n=>n[0]).join("") %>

                                        <% } %>
                                    </div>
                                    <div>
                                        <h4><%= emp.full_name %></h4>
                                        <p><%= emp.employee_code %></p>
                                    </div>
                                </div>
                                <div class="dept"><%= emp.department %></div>
                                <div><%= emp.attendance %></div>
                                <div><%= emp.position %></div>
                                <div><%= emp.joining_date %></div>
                                <div><%= emp.status %></div>
                                <div><%= emp.email %></div>
                                <div class="act-icon">
                                    <a href="/employees/<%= emp.employee_code %>/edit"><i class="bi bi-pencil-fill"></i></a>
                                    <form action="/employees/<%= emp.employee_code %>?_method=DELETE" method="POST" class="delete-form">
                                        <button type="submit" class="delete-btn">
                                            <i class="bi bi-trash-fill"></i>
                                        </button>
                                    </form>
                                    <form action="/employees/<%= emp.employee_code %>" method="Get" class="show-form">
                                        <button type="submit" class="details-btn">
                                            <i class="bi bi-three-dots-vertical"></i>
                                        </button>
                                    </form>
                                </div>
                                <!-- <a href="/products/<%= emp.employee_code %>">Show details</a> -->
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="employeeModal" class="modal-overlay">
        <div class="modal-box">
            <h2>Add New Employee</h2>
            <form class="employee-form" action="/employees" method="POST" enctype="multipart/form-data">
                    <div class="modal-layout">
                    
                        <!-- LEFT PROFILE AREA -->
                        <div class="profile-section">
                        
                            <div class="profile-upload">
                                <i class="bi bi-person-circle"></i>
                                <label for="profilePic">Upload Photo</label>
                                <input type="file" id="profilePic" name="profilePic" accept="image/*"
                                />
                            </div>
                        
                            <div class="input-box">
                                <label>LinkedIn</label>
                                <input type="url" id="linkedin" name="linkedin" placeholder="linkedin.com/in/name">
                                
                            </div>
                        
                            <div class="input-box">
                                <label>Resume</label>
                                <input type="file" id="resume" name="resume" accept=".pdf,.doc,.docx">
                            </div>
                        
                        </div>
                    
                    
                        <!-- RIGHT FORM AREA -->
                        <div class="details-section">
                        
                            <h3>Personal Information</h3>
                        
                            <div class="form-grid">
                            
                                <div class="input-box">
                                    <label>Full Name</label>
                                    <input type="text" name="empName" placeholder="Employee Name">
                                    <span class="errorBox"></span>
                                </div>
                            
                                <div class="input-box">
                                    <label>Email</label>
                                    <input type="email" name="empMail" placeholder="employee@gmail.com">
                                    <span class="errorBox"></span>
                                </div>

                                <div class="input-box">
                                    <label>Gender</label>
                                    <select name="gender">
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                            
                                <div class="input-box">
                                    <label>Phone</label>
                                    <input type="tel" name="empPh" placeholder="+91 XXXXX XXXXX">
                                    <span class="errorBox"></span>
                                </div>
                            
                            
                                <div class="input-box">
                                    <label>Department</label>
                                    <select name="empDept">
                                        <option>Engineering</option>
                                        <option>Marketing</option>
                                        <option>HR</option>
                                    </select>
                                    <span class="errorBox"></span>
                                </div>
                            
                            
                                <div class="input-box">
                                    <label>Designation</label>
                                    <input type="text" name="posn" placeholder="Software Engineer">
                                    <span class="errorBox"></span>
                                </div>
                            
                            
                                <div class="input-box">
                                    <label>Status</label>
                                    <select name="status">
                                        <option>Active</option>
                                        <option>Inactive</option>
                                        <option>On Leave</option>
                                    </select>
                                    <span class="errorBox"></span>
                                </div>
                            
                            </div>
                        
                            <div class="modal-buttons">
                                <button type="button" id="closeModal" class="cnbtn">Cancel</button>
                                <button type="submit" class="embtn">
                                    Add Employee
                                </button>
                            </div>
                        
                        </div>
                    
                    </div>
                
                </form>
        </div>
    </div>

    <footer>
        <div class="footer">
            <p>@Employee Management System</p>
        </div>
    </footer>

    <script src="/js/empl.js"></script>
    <script src="/js/addempscript.js"></script>
    <script>
        document.getElementById("closeModal").addEventListener("click", () => {
            document.getElementById("employeeModal").style.display = "none";
        });
        document.getElementById("addEmployeeBtn").addEventListener("click", () => {
            document.getElementById("employeeModal").style.display = "flex";
        });
    </script>
    <script src="/script2.js"></script>
    <script src="/js/emp.js"></script>
</body>
</html>
