<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="/css/var.css?v=1.2">
    <link rel="stylesheet" href="/css/global.css?v=1.2">
    <link rel="stylesheet" href="/css/nav.css?v=1.2">
    <link rel="stylesheet" href="/css/sidebar.css?v=1.2">
    <link rel="stylesheet" href="/css/dashboard.css?v=1.2">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
</head>
<body>
    <div class="container">
        <div class="cont">
            <nav class="nav-bar">
                <div class="left">
                    <div class="menu" id="menu-btn">
                        <i class="bi bi-list"></i>
                    </div>
                    <div class="title">
                        <h1>PreLeave</h1>
                    </div>
                    <div class="search-bar">
                        <input type="text" id="search-bar">
                        <i class="bi bi-search"></i>
                    </div>
                </div>
                <div class="right">
                    <div class="notif">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <div class="toggle-dn">
                        <i class="bi bi-brightness-high-fill" id="theme-toggle"></i>
                    </div>
                    <div class="profile" onclick="window.location.href='/profile'">
                        <i class="bi bi-person-circle"></i>
                    </div>
                </div>
            </nav>

            <div class="main-area">
                 <aside class="sidebar" id="sidebar">
                    <div class="aside-nav">
                        <a href="/dashboard" class="menu-item active">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/employees" class="menu-item">
                            <i class="bi bi-people-fill"></i>
                            <span>Employees</span>
                        </a>
                        <a href="/leaves" class="menu-item">
                            <i class="bi bi-calendar-check"></i>
                            <span>Leave Requests</span>
                        </a>
                        <a href="/attendance" class="menu-item"> 
                            <i class="bi bi-clock-history"></i>
                            <span>Attendance</span>
                        </a>
                        <a href="/calendar" class="menu-item">
                            <i class="bi bi-calendar-date-fill"></i>
                            <span>Calendar</span>
                        </a>

                        <a href="/changepass" class="menu-item">
                            <i class="bi bi-gear-fill"></i>
                            <span>Settings</span>
                        </a>
                        <a href="/login" class="menu-item">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </aside>

                <main class="content" id="main-cont">
                    <section class="kpi-cards">
                        <div class="kpi-container">
                            <div class="kpi-card">
                                <div class="ls">
                                    <i class="bi bi-people-fill"></i>
                                    <h3>Total Employees</h3>
                                </div>
                                <div class="context">
                                    <h1><%= totalEmployees %></h1>
                                </div>
                            </div>
                            <div class="kpi-card">
                                <div class="ls pending">
                                    <i class="bi bi-hourglass-split"></i>
                                    <h3>Active Employees</h3>
                                </div>
                                <div class="context">
                                    <h1><%= activeEmployees %></h1>
                                </div>
                            </div>
                            <div class="kpi-card">
                                <div class="ls approved">
                                    <i class="bi bi-check-circle-fill"></i>
                                    <h3>On Leave</h3>
                                </div>
                                <div class="context">
                                    <h1><%= onLeaveEmployees %></h1>
                                </div>
                            </div>
                            <div class="kpi-card">
                                <div class="ls rejected">
                                    <i class="bi bi-x-circle-fill approve"></i>
                                    <h3>Inactive Employees</h3>
                                </div>
                                <div class="context">
                                    <h1><%= inactiveEmployees %></h1>
                                </div>
                            </div>
                        </div>
                    </section>
    
                    <section class="mid-section">
                        <div class="middle-area">
                            <div class="calendar-card">
                                <h3>📅 Leave Calendar</h3>
                                <iframe src="https://calendar.google.com/calendar/embed?src=YOUR_CALENDAR_ID" style="border:0" width="95%" height="90%"></iframe>
                            </div>

                            <div class="leaves-card">
                                <div class="leaves-header">
                                    <h3>Leaves Today (<%= leaves.filter(r => r.status === 'Approved').length %>)</h3>
                                    <a href="/leaves">View all</a>
                                </div>
                                <% leaves.filter(r => r.status === 'Approved').forEach(re => { %>
                                    <div class="leave-item">
                                        <div class="employee">
                                            <div class="avatar"><%= re.full_name[0] %></div>
                                            <div>
                                                <h4><%= re.full_name %></h4>
                                                <p>Employee</p>
                                            </div>
                                        </div>
                                        <span class="tag casual"><%= re.leave_type %></span>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    </section>
    
                    <div class="table-area">
                        <div class="recent-leaves">
                            <div class="recent-header">
                                <h2>Recent Leaves</h2>
                                <a href="/leaves">View all</a>
                            </div>

                            <div class="table-row table-heading">
                                <div>Employee</div>
                                <div>Leave Type</div>
                                <div>From</div>
                                <div>To</div>
                                <div>Days</div>
                                <div>Status</div>
                                <div>Actions</div>
                            </div>

                            <% leaves.forEach(req => { %>
                                <div class="table-row">
                                    <div class="employee">
                                        <div class="avatar"><%= req.full_name[0] %></div>
                                        <span><%= req.full_name %></span>
                                    </div>
                                    <div>
                                        <span class="tag casual"><%= req.leave_type %></span>
                                    </div>
                                    <div><%= formatDate(req.start_date) %></div>
                                    <div><%= formatDate(req.end_date) %></div>
                                    <div><%=req.total_days %></div>
                                    <div>
                                        <span class="tag <%= req.status.toLowerCase() %>">● <%= req.status %></span>
                                    </div>
                                    <div>
                                        <a href="/leaves/<%= req.leave_id %>/del"><i class="bi bi-trash-fill"></i></a>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </main>
            </div>
        </div>
    </div>
    <footer>
        <div class="footer">
            <p>@Employee Management System</p>
        </div>
    </footer>

    <script src="/script2.js"></script>
</body>
</html>
