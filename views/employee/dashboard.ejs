<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Dashboard</title>
    
    <!-- CSS Links -->
    <link rel="stylesheet" href="/css/var.css?v=1.2">
    <link rel="stylesheet" href="/css/global.css?v=1.2">
    <link rel="stylesheet" href="/css/nav.css?v=1.2">
    <link rel="stylesheet" href="/css/sidebar.css?v=1.2">
    <link rel="stylesheet" href="/employee/css/emp-style.css?v=1.2">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="container">
        <div class="box">
            <!-- NAV BAR -->
            <nav class="nav-bar">
                <div class="left">
                    <div class="menu" id="menu-btn">
                        <i class="bi bi-list"></i>
                    </div>
                    <div class="title">
                        <h1>PreLeave</h1>
                    </div>
                </div>
                <div class="right">
                    <div class="notif">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <div class="toggle-dn">
                        <i class="bi bi-brightness-high-fill" id="theme-toggle"></i>
                    </div>
                    <div class="profile" onclick="window.location.href='/employee/profile'">
                        <% if (employee.profile_picture) { %>
                            <img src="/<%= employee.profile_picture %>" alt="Profile" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 1px solid var(--border-light);">
                        <% } else { %>
                            <i class="bi bi-person-circle"></i>
                        <% } %>
                    </div>
                </div>
            </nav>

            <div class="main-area">
                <!-- SIDEBAR -->
                <aside class="sidebar" id="sidebar">
                    <div class="aside-nav">
                        <a href="/employee/dashboard" class="menu-item active">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                        <a href="/employee/profile" class="menu-item">
                            <i class="bi bi-person-badge-fill"></i>
                            <span>My Profile</span>
                        </a>
                        <a href="/employee/apply" class="menu-item">
                            <i class="bi bi-calendar-plus-fill"></i>
                            <span>Apply for Leave</span>
                        </a>
                        <a href="/employee/history" class="menu-item">
                            <i class="bi bi-calendar-check"></i>
                            <span>Leave History</span>
                        </a>
                        <a href="/employee/rules" class="menu-item">
                            <i class="bi bi-journal-text"></i>
                            <span>Leave Rules</span>
                        </a>
                        <a href="/employee/contact" class="menu-item">
                            <i class="bi bi-envelope-fill"></i>
                            <span>Contact Us</span>
                        </a>
                        <a href="/logout" class="menu-item">
                            <i class="bi bi-box-arrow-right"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </aside>

                <!-- MAIN CONTENT -->
                <main class="main-container" id="main-cont">
                    <div class="welcome-banner" style="text-align: left; margin-bottom: 2rem;">
                        <h2 style="font-size: 1.8rem; font-weight: 700; color: var(--heading-primary);">Welcome Back, <%= employee.full_name %>!</h2>
                        <p style="color: var(--heading-secondary); font-size: 0.95rem;">ID: <%= employee.employee_code %> | <%= employee.position %> - <%= employee.department %></p>
                    </div>

                    <div class="kpi-row">
                        <div class="kpi-card success">
                            <div class="kpi-info">
                                <h3>Paid Leaves Remaining</h3>
                                <h1><%= paidRemaining %></h1>
                            </div>
                            <i class="bi bi-calendar-check-fill"></i>
                        </div>
                        <div class="kpi-card warn">
                            <div class="kpi-info">
                                <h3>Casual Leaves Remaining</h3>
                                <h1><%= casualRemaining %></h1>
                            </div>
                            <i class="bi bi-calendar-week-fill"></i>
                        </div>
                        <div class="kpi-card err">
                            <div class="kpi-info">
                                <h3>Sick Leaves Remaining</h3>
                                <h1><%= sickRemaining %></h1>
                            </div>
                            <i class="bi bi-hospital-fill"></i>
                        </div>
                        <div class="kpi-card">
                            <div class="kpi-info">
                                <h3>Pending Leaves</h3>
                                <h1><%= pendingLeaves %></h1>
                            </div>
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                    </div>

                    <div class="section-card">
                        <div class="section-header">
                            <h2>Recent Leave Requests</h2>
                            <a href="/employee/apply">Apply New Leave</a>
                        </div>
                        <div class="table-wrapper">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Leave Type</th>
                                        <th>Start Date</th>
                                        <th>End Date</th>
                                        <th>Total Days</th>
                                        <th>Reason</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (leaves && leaves.length > 0) { %>
                                        <% leaves.forEach(l => { %>
                                            <tr>
                                                <td><%= l.leave_type %></td>
                                                <td><%= new Date(l.start_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                                <td><%= new Date(l.end_date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                                                <td><%= l.total_days %> <%= l.total_days > 1 ? 'Days' : 'Day' %></td>
                                                <td><%= l.reason %></td>
                                                <td>
                                                    <% if (l.status === 'Approved') { %>
                                                        <span class="status-badge approved">● Approved</span>
                                                    <% } else if (l.status === 'Rejected') { %>
                                                        <span class="status-badge rejected">● Rejected</span>
                                                    <% } else { %>
                                                        <span class="status-badge pending">● Pending</span>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" style="text-align: center; color: var(--heading-secondary); padding: 2rem;">No leave requests found.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </main>
            </div>
        </div>
    </div>

    <footer>
        <div class="footer">
            <p>&copy; 2026 PreLeave Employee Leave Management System</p>
        </div>
    </footer>

    <!-- JS script for sidebar/theme toggles -->
    <script src="/employee/js/nav-handler.js"></script>
</body>
</html>
