<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password</title>
    <link rel="stylesheet" href="/css/var.css?v=1.2">
    <link rel="stylesheet" href="/css/global.css?v=1.2">
    <link rel="stylesheet" href="/css/changepass.css?v=1.2">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
</head>
<body>
    <div class="container">
        <div class="changepass">
            <h2>Change Password</h2>
            <form action="/changepass" method="POST">
                <div class="password-wrapper">
                    <input type="password" name="oldPassword" placeholder="Enter your old password" class="oldpass" required>
                    <i class="bi bi-eye-slash toggle-password"></i>
                </div>
                <div class="password-wrapper">
                    <input type="password" name="newPassword" placeholder="Enter New Password" class="oldpass" required>
                    <i class="bi bi-eye-slash toggle-password"></i>
                </div>
                <div class="password-wrapper">
                    <input type="password" name="confirmPassword" placeholder="Re-enter new password" class="newpass" required>
                    <i class="bi bi-eye-slash toggle-password"></i>
                </div>
                <button type="submit" id="cp">Change Password</button>
            </form>
        </div>
    </div>
    <script src="/script2.js"></script>
</body>
</html>
